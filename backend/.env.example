# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co
# Service Role Key (secret — server-side only, NEVER expose to frontend)
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon Key (safe for frontend use)
# Supabase Dashboard → Settings → API → anon public key
SUPABASE_ANON_KEY=eyJ...

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Bootstrap premier admin ───────────────────────────────────────────────────
# Secret one-shot pour créer le premier compte admin via POST /api/auth/bootstrap
# Supprimer après utilisation
BOOTSTRAP_SECRET=

# ─── Brevo (email transactionnel) ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=contact@neotravel.fr
BREVO_SENDER_NAME=NeoTravel
BREVO_REPLY_TO=commercial@neotravel.fr
# brevo | console  (console = pas d'envoi réel, log dans la console)
EMAIL_PROVIDER=console

# ─── LLM (chatbot devis) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=openai
