# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/neotravel?retryWrites=true&w=majority

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=7d

# ─── Brevo (email transactionnel) ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=contact@neotravel.fr
BREVO_SENDER_NAME=NeoTravel
BREVO_REPLY_TO=commercial@neotravel.fr
# brevo | console  (console = pas d'envoi réel, log dans la console)
EMAIL_PROVIDER=console

# ─── LLM (chatbot devis) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=openai

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET=
