# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key (Dashboard → Settings → API)
SUPABASE_ANON_KEY=eyJ...           # anon key

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Brevo (email transactionnel) ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=contact@neotravel.fr
BREVO_SENDER_NAME=NeoTravel
BREVO_REPLY_TO=commercial@neotravel.fr
# brevo | console  (console = pas d'envoi réel, log dans la console)
EMAIL_PROVIDER=console

# ─── LLM (chatbot devis) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Bootstrap premier admin ───────────────────────────────────────────────────
BOOTSTRAP_SECRET=change-me-before-use
