# ─── Backend URL (OBLIGATOIRE en production) ───────────────────────────────
# En développement local : http://localhost:4000
# En production (Vercel) : https://neotravel-mvp.onrender.com
# Sans ce paramètre, register/login/dashboard ne fonctionneront PAS.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Anthropic (server-side uniquement — ne pas préfixer NEXT_PUBLIC_) ──────
# Créer sur https://console.anthropic.com/
# NE JAMAIS committer cette clé — elle reste dans .env.local
ANTHROPIC_API_KEY=sk-ant-...
