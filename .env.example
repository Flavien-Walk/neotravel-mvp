# ─── Backend URL (Express API) ─────────────────────────────────────────────
# En développement local : http://localhost:4000
# En production (Render) : https://neotravel-mvp.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Supabase (public — safe to expose to browser) ──────────────────────────
# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Supabase Dashboard → Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Anthropic (server-side uniquement — ne pas préfixer NEXT_PUBLIC_) ──────
# Créer sur https://console.anthropic.com/
# NE JAMAIS committer cette clé — elle reste dans .env.local
ANTHROPIC_API_KEY=sk-ant-...
